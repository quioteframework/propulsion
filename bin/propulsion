#!/usr/bin/env php
<?php

$autoloadCandidates = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
];

foreach ($autoloadCandidates as $autoloadPath) {
    if (is_file($autoloadPath)) {
        require_once $autoloadPath;
        break;
    }
}

if (!class_exists(\Composer\Autoload\ClassLoader::class, false)) {
    fwrite(STDERR, "Could not find Composer autoload.php.\n");
    exit(1);
}

use Symfony\Component\Console\Application;
use Propulsion\Generator\Command\ModelBuildCommand;
use Propulsion\Generator\Command\SqlBuildCommand;
use Propulsion\Generator\Command\InitCommand;
use Propulsion\Generator\Command\SchemaReverseCommand;
use Propulsion\Generator\Command\GraphvizBuildCommand;
use Propulsion\Generator\Command\SqlExecCommand;
use Propulsion\Generator\Command\SqlDiffCommand;
use Propulsion\Generator\Command\MigrationStatusCommand;
use Propulsion\Generator\Command\MigrationUpCommand;
use Propulsion\Generator\Command\MigrationDownCommand;
use Propulsion\Generator\Command\DataDumpCommand;
use Propulsion\Generator\Command\DataSqlCommand;

$application = new Application('Propulsion', '1.0.0-dev');

$application->addCommand(new ModelBuildCommand());
$application->addCommand(new SqlBuildCommand());
$application->addCommand(new InitCommand());
$application->addCommand(new SchemaReverseCommand());
$application->addCommand(new GraphvizBuildCommand());
$application->addCommand(new SqlExecCommand());
$application->addCommand(new SqlDiffCommand());
$application->addCommand(new MigrationStatusCommand());
$application->addCommand(new MigrationUpCommand());
$application->addCommand(new MigrationDownCommand());
$application->addCommand(new DataDumpCommand());
$application->addCommand(new DataSqlCommand());

$application->run();
