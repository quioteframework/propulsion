{
  "name": "quioteframework/propulsion",
  "description": "Propulsion is an object-relational mapping (ORM) for PHP, forked from Propulsion 1.",
  "keywords": ["ORM"],
  "license": "MIT",
  "authors": [
    {
      "name": "William Durand",
      "email": "william.durand1@gmail.com",
      "homepage": "http://www.willdurand.fr"
    }
  ],
  "require": {
    "php": ">=8.5.0",
    "symfony/console": "^8.0",
    "symfony/yaml": "^8.0",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "phing/phing": "^3.0",
    "testcontainers/testcontainers": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Propulsion\\Generator\\": "generator/Lib/",
      "Propulsion\\": "runtime/Lib/"
    }
  },
  "bin": [
    "bin/propulsion"
  ]
}
