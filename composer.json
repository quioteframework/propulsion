{
  "name": "quioteframework/propulsion",
  "description": "Propulsion is an object-relational mapping (ORM) for PHP, forked from Propel 1.",
  "keywords": ["ORM"],
  "license": "MIT",
  "authors": [
    {
      "name": "Markus Lervik",
      "email": "markus@saake.li"
    },
    {
      "name": "Propel 1 contributors"
    }
  ],
  "require": {
    "php": ">=8.5.0",
    "symfony/console": "^8.0",
    "symfony/yaml": "^8.0",
    "psr/log": "^3.0",
    "psr/event-dispatcher": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "testcontainers/testcontainers": "^1.0",
    "phpstan/phpstan": "^2.2",
    "symfony/http-client": "^8.1",
    "rector/rector": "^2.5"
  },
  "autoload": {
    "psr-4": {
      "Propulsion\\Generator\\": "generator/Lib/",
      "Propulsion\\": "runtime/Lib/"
    }
  },
  "bin": [
    "bin/propulsion"
  ],
  "scripts": {
    "test:cleanup-containers": [
      "docker ps -aq --filter label=propulsion.test-container=true | xargs -r docker stop --",
      "docker ps -aq --filter label=propulsion.test-container=true | xargs -r docker rm --"
    ],
    "test:worker": "php test/worker/driver.php",
    "analyse": "phpstan analyse"
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
