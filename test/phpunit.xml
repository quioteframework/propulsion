<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/12.0/phpunit.xsd"
    bootstrap="./bootstrap.php"
    cacheDirectory=".phpunit.cache"
    executionOrder="depends,defects"
    beStrictAboutOutputDuringTests="true"
    failOnWarning="true"
    colors="true">

    <testsuites>
        <testsuite name="Propulsion Generator Tests">
            <directory>./testsuite/generator</directory>
        </testsuite>
        <testsuite name="Propulsion Runtime Tests">
            <directory>./testsuite/runtime</directory>
        </testsuite>
        <testsuite name="Propulsion Misc Tests">
            <directory>./testsuite/misc</directory>
        </testsuite>
    </testsuites>

    <source restrictNotices="true" restrictWarnings="true">
        <include>
            <directory>../generator/Lib</directory>
            <directory>../runtime/Lib</directory>
        </include>
        <exclude>
            <!-- Class-less file: a single `return [100-entry array];` statement.
                 pcov (correctly) tracks this as one executable line, which is hit
                 on every run, but PHPUnit's static "coverable lines" analysis
                 counts each array entry as its own line, making ~102 fully-exercised
                 lines look uncovered. Excluded to avoid deflating the real number. -->
            <file>../runtime/Lib/legacy-class-map.php</file>
        </exclude>
    </source>

    <php>
        <ini name="error_reporting" value="E_ALL"/>
        <ini name="display_errors" value="On"/>
        <ini name="display_startup_errors" value="On"/>
        <ini name="memory_limit" value="512M"/>
    </php>

</phpunit>
